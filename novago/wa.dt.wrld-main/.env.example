# ==============================================
# WhatsApp Bot - Environment Configuration
# ==============================================

# API Authentication
# REQUIRED: Shared API key for both services
API_KEY=your-secret-api-key-here

# WhatsApp API Service Configuration
# The core service that manages WhatsApp sessions
BASE_WEBHOOK_URL=http://whatsapp-service:3001/events
SESSIONS_PATH=/app/sessions
MAX_ATTACHMENT_SIZE=10485760
SET_MESSAGES_AS_SEEN=false
ENABLE_SWAGGER_ENDPOINT=true
RECOVER_SESSIONS=true
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=1000

# WhatsApp n8n Service (Thin Wrapper) Configuration
# Bridges n8n nodes to whatsapp-api
WHATSAPP_API_URL=http://whatsapp-api:3000

# MongoDB Configuration
# Used for webhook registrations and config storage
MONGODB_URI=mongodb://mongodb:27017/whatsapp-service

# Admin UI Credentials (for /admin/sessions and /admin/logs routes)
# REQUIRED for admin UI access - leave empty to disable admin UI
WHATSAPP_SERVICE_ADMIN_USER=admin
WHATSAPP_SERVICE_ADMIN_PASSWORD=change-this-secure-password

# Optional: Environment
NODE_ENV=production

# Optional: Port overrides (default: 3000 for API, 3001 for service)
# PORT=3000

# ==============================================
# Docker Compose Configuration
# ==============================================
# Copy this file to .env and modify as needed

# Project name (used for container naming and isolation)
COMPOSE_PROJECT_NAME=wa

# Port configuration (change to avoid conflicts with other projects)
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
MONGODB_PORT=27017
WHATSAPP_API_PORT=3000
SERVICE_PORT=3001
