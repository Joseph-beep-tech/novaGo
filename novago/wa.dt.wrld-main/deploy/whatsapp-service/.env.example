# WhatsApp Service - Production Environment
# Copy this file to .env and fill in the values

# API authentication key
API_KEY=your-secure-api-key

# WhatsApp API connection (uses Docker network)
WHATSAPP_API_URL=http://wwebjs-api:3000

# MongoDB authentication
MONGO_USER=wabot
MONGO_PASSWORD=your-secure-mongo-password

# Admin UI authentication
WHATSAPP_SERVICE_ADMIN_USER=admin
WHATSAPP_SERVICE_ADMIN_PASSWORD=your-secure-admin-password

# nginx-proxy domain (override per server)
# VIRTUAL_HOST=wa-service.aziziafrica.com
# LETSENCRYPT_HOST=wa-service.aziziafrica.com
