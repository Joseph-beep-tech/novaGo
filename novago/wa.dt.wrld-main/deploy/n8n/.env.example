# n8n Environment Variables
#
# Copy this file to .env and fill in the values.
# These are passed to n8n container and accessible via $env.* in workflows.

# n8n API authentication (for n8n's own API)
API_KEY=your-n8n-api-key-uuid

# wwebjs-api authentication (for sending WhatsApp messages)
WHATSAPP_API_KEY=your-whatsapp-api-key

# whatsapp-service authentication (for user registration, tags, etc.)
SERVICE_API_KEY=your-service-api-key

# nginx-proxy configuration
VIRTUAL_HOST=flow.example.com
LETSENCRYPT_HOST=flow.example.com
LETSENCRYPT_EMAIL=admin@example.com

# Optional: Set log level for debugging (debug, info, warn, error)
# N8N_LOG_LEVEL=info
