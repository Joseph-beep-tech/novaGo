# Keycloak Configuration
# Copy to .env and fill in values

# Database password for Keycloak's PostgreSQL
KC_DB_PASSWORD=your-secure-postgres-password

# Keycloak admin console credentials
KEYCLOAK_ADMIN_PASSWORD=your-secure-admin-password

# Hostname configuration
# For local development:
KC_HOSTNAME=localhost
KC_HOSTNAME_PORT=8080

# For production (behind reverse proxy):
# KC_HOSTNAME=auth.dater.world
# KC_HOSTNAME_PORT=443

# Port mapping (optional, defaults to 8080)
# KEYCLOAK_PORT=8080
