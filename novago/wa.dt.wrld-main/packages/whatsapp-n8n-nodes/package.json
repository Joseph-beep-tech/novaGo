{
  "name": "@dater/n8n-nodes-whatsapp-bot",
  "version": "1.0.0",
  "description": "n8n community nodes for WhatsApp Bot integration with advanced features",
  "keywords": [
    "n8n-community-node-package",
    "whatsapp",
    "whatsapp-web",
    "messaging",
    "automation",
    "bot",
    "groups",
    "polls",
    "media"
  ],
  "license": "MIT",
  "homepage": "https://github.com/dater/n8n-nodes-whatsapp-bot",
  "author": {
    "name": "Dater Team",
    "email": "admin@dater.world"
  },
  "engines": {
    "node": ">=18.10"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npx tsx copy-assets.ts",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "deploy": "npx ts-node deploy/deploy.ts",
    "deploy:backup": "npx ts-node deploy/deploy.ts --backup-only",
    "deploy:verify": "npx ts-node deploy/deploy.ts --verify-only"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/WhatsAppBotApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/WhatsAppBot/WhatsAppBot.node.js",
      "dist/nodes/WhatsAppBotTrigger/WhatsAppBotTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node-ssh": "^7.0.1",
    "@types/node": "^18.16.16",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.15.1",
    "node-ssh": "^13.2.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "n8n-core": "^1.15.1",
    "axios": "^1.6.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}