# WhatsApp Dashboard Environment Configuration

# Mock API Mode
# Set to 'true' to use MSW mock handlers instead of real API
# Set to 'false' or remove to use real backend API
VITE_USE_MOCK_API=true

# API Base URL (only used when VITE_USE_MOCK_API=false)
# VITE_API_BASE_URL=http://localhost:3001

# Session ID for WhatsApp connection
# VITE_SESSION_ID=mysession
