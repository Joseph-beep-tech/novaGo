{
  "name": "@dater/whatsapp-service",
  "version": "0.6.0",
  "description": "WhatsApp event processing service with tag-based routing, RAG memory, and user management",
  "main": "dist/index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./src/views/styles.css --minify",
    "tsoa:spec": "tsoa spec",
    "tsoa:routes": "tsoa routes",
    "tsoa": "npm run tsoa:spec && npm run tsoa:routes",
    "prebuild": "npm run tsoa",
    "build": "npm run build:css && tsc",
    "clean": "rm -rf dist",
    "dev": "npm run tsoa && ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "npm run tsoa && tsc --noEmit"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "n8n",
    "automation",
    "typescript"
  ],
  "author": "Dater Team",
  "license": "MIT",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.7.0",
    "axios": "^1.6.2",
    "bullmq": "^5.1.0",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "mongoose": "^8.1.0",
    "openai": "^4.28.0",
    "openid-client": "^5.6.4",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.18.0",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.11",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/supertest": "^2.0.16",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.4",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsoa": "^6.6.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
