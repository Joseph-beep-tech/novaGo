# WhatsApp n8n Service - Production Environment Configuration
# Copy this file to .env and fill in the values

# Required: API Key for authentication (should match wwebjs-api)
API_KEY=your-secure-api-key-here

# WhatsApp API URL - use container name if on shared network
# Option A: Direct container reference (if connected to wwebjs-api network)
WHATSAPP_API_URL=http://wwebjs-api:3000
# Option B: External URL (if on separate network)
# WHATSAPP_API_URL=https://wa.dater.world

# Admin UI credentials for /admin endpoints
WHATSAPP_SERVICE_ADMIN_USER=admin
WHATSAPP_SERVICE_ADMIN_PASSWORD=your-secure-admin-password-here
